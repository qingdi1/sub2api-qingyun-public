# Copy to .env.qingyun. Use exact, matching Qingyun image tags.
BIND_HOST=0.0.0.0
SERVER_PORT=8888
SERVER_MODE=release
RUN_MODE=standard
TZ=Asia/Shanghai

SUB2API_IMAGE=ghcr.io/qingdi1/sub2api-qingyun-public:0.1.158-qingyun.3
UPDATE_AGENT_IMAGE=ghcr.io/qingdi1/sub2api-qingyun-update-agent:0.1.158-qingyun.3

POSTGRES_USER=sub2api
POSTGRES_PASSWORD=replace-with-a-local-secret
POSTGRES_DB=sub2api
REDIS_PASSWORD=

ADMIN_EMAIL=admin@qingyun.local
ADMIN_PASSWORD=replace-with-a-local-admin-password
JWT_SECRET=replace-with-a-64-character-random-secret
TOTP_ENCRYPTION_KEY=replace-with-a-64-character-random-secret

DEMO_ACCOUNT_ENABLED=true
DEMO_ACCOUNT_EMAIL=demo@qingyun.local
DEMO_ACCOUNT_PASSWORD=replace-with-a-local-demo-password
DEMO_ACCOUNT_DISPLAY_NAME=Qingyun Demo

UPDATE_DOCKER_AGENT_TOKEN=replace-with-a-32-byte-random-token
